{
  "name": "marathon-runlog",
  "private": true,
  "version": "1.0.0",
  "description": "Marathon run tracker - screenshot powered stats",
  "scripts": {
    "dev": "RUNLOG_DEV=1 vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "date-fns": "^3.0.0",
    "framer-motion": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.2.0",
    "recharts": "^2.12.0",
    "screenshot-desktop": "^1.15.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.runlog.marathon",
    "productName": "RunLog",
    "directories": {
      "output": "../release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!**/__pycache__/**",
          "!*.pyc",
          "!media_uploads/**",
          "!runlog.db",
          "!.env"
        ]
      }
    ],
    "win": {
      "target": ["dir"],
      "sign": false
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/screenshot-desktop/**"
    ]
  }
}
