{
  "name": "runlog",
  "private": true,
  "version": "1.0.0",
  "author": "Jamie Ballard",
  "description": "Local-first desktop companion for Marathon — AI-powered stats, narratives, and highlight clips",
  "scripts": {
    "dev": "cross-env RUNLOG_DEV=1 vite",
    "build": "cross-env NODE_ENV=production tsc && cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "date-fns": "^3.0.0",
    "electron-updater": "^6.3.0",
    "framer-motion": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.10",
    "wait-on": "^7.2.0"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.runlog.exe",
    "productName": "runlog",
    "directories": {
      "output": "../release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!**/__pycache__/**",
          "!*.pyc",
          "!media_uploads/**",
          "!runlog.db",
          "!.env",
          "!recorder/target/**",
          "!recorder/src/**",
          "!recorder/Cargo.toml",
          "!recorder/Cargo.lock"
        ]
      },
      {
        "from": "../backend/recorder/target/release/runlog-recorder.exe",
        "to": "backend/runlog-recorder.exe"
      }
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "electron/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "OWNER",
      "repo": "runlog.exe"
    },
    "asar": true
  }
}
